# Copy this file to `apps/<app>/.env.local` for each Next.js app you run locally
# (Next.js loads env from the app package root, not the monorepo root).
#
# Convex deployment (browser-safe; not a secret):
NEXT_PUBLIC_CONVEX_URL=https://watchful-chameleon-570.convex.cloud
#
# OAuth client secrets belong on the Convex deployment, not here. See README
# "Convex Auth (password + OAuth)" for SITE_URL, AUTH_*_ID/SECRET, and callback URLs.
#
# Production forum: https://discuss.createconomy.com/feed — Convex SITE_URL for that app:
# https://discuss.createconomy.com (origin only).
