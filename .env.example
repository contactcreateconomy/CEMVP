# =============================================================================
# Monorepo environment reference
# =============================================================================
# Next.js loads env from each app’s package root only. For local dev, copy the
# matching file to that app’s `.env.local`:
#
#   apps/forum/.env.example       → apps/forum/.env.local
#   apps/seller/.env.example      → apps/seller/.env.local
#   apps/admin/.env.example       → apps/admin/.env.local
#   apps/marketplace/.env.example → apps/marketplace/.env.local
#
# Each app needs:
NEXT_PUBLIC_CONVEX_URL=

# OAuth (Google, GitHub, Facebook), JWT keys, SITE_URL, and ADMIN_EMAILS are set
# on the Convex deployment — not in Next.js. Full list:
#   convex/.env.example
#
# Set from repo root, e.g.:
#   npx convex env set AUTH_GOOGLE_ID "…"
#   npx convex env set AUTH_GOOGLE_SECRET "…"
#
# Production forum: https://discuss.createconomy.com/feed
# Convex SITE_URL for that app: https://discuss.createconomy.com
