# Copy to `.env.local` in this directory (gitignored).

# --- Next.js (this app) — required ---
# Local dev: use the dev deployment. Production (Vercel): set prod URL in Vercel env vars only.
NEXT_PUBLIC_CONVEX_URL=

# Local example (dev):
# NEXT_PUBLIC_CONVEX_URL=https://watchful-chameleon-570.convex.cloud

# Production example (Vercel project env — do not use in local .env.local):
# NEXT_PUBLIC_CONVEX_URL=https://energetic-kangaroo-55.convex.cloud

# --- Convex deployment (NOT in this file) ---
# OAuth secrets and SITE_URL live on Convex. See ../../convex/.env.example
