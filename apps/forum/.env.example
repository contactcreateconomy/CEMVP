# Copy to `.env.local` in this directory (gitignored).

# --- Next.js (this app) — required ---
# Convex → Settings → Deployment URL (ends in .convex.cloud)
NEXT_PUBLIC_CONVEX_URL=

# Example:
# NEXT_PUBLIC_CONVEX_URL=https://watchful-chameleon-570.convex.cloud

# Production forum: https://discuss.createconomy.com/feed
# Convex SITE_URL for production OAuth: https://discuss.createconomy.com (origin only).

# --- Convex deployment (NOT in this file) ---
# Google / GitHub / Facebook client ID & secret, JWT keys, SITE_URL, etc. are set
# on your Convex backend. Template with all names: ../../convex/.env.example
