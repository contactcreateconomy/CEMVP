# =============================================================================
# Convex deployment environment variables (backend / auth)
# =============================================================================
# Set these in the Convex Dashboard → Settings → Environment Variables, or from
# the monorepo root:
#   npx convex env set SITE_URL "http://localhost:3000"
#   npx convex env set AUTH_GOOGLE_ID "your-id.apps.googleusercontent.com"
#   npx convex env set AUTH_GOOGLE_SECRET "your-secret"
#
# Do NOT add OAuth secrets to Next.js apps — Auth.js callbacks run on Convex
# (HTTP Actions on your *.convex.site host).
#
# OAuth redirect / callback URLs (replace DEPLOYMENT with your Convex project):
#   https://DEPLOYMENT.convex.site/api/auth/callback/google
#   https://DEPLOYMENT.convex.site/api/auth/callback/github
#   https://DEPLOYMENT.convex.site/api/auth/callback/facebook
#
# Docs: https://labs.convex.dev/auth/setup/manual
# =============================================================================

# App origin users return to after OAuth (no path). Examples:
#   http://localhost:3000
#   https://discuss.createconomy.com
SITE_URL=

# Issuer for JWTs; often set automatically on Convex Cloud. Used in convex/auth.config.ts
CONVEX_SITE_URL=

# Convex Auth — RS256 keypair. Docs: https://labs.convex.dev/auth/setup/manual
# 1) Copy this file to .env.local and fill other vars.
# 2) From repo root: `pnpm convex:gen-jwt` (updates JWT_PRIVATE_KEY + JWKS in convex/.env.local).
# 3) Sync to Convex: Dashboard → Environment Variables, or `pnpm exec convex env set …`
#    (use `convex env set JWT_PRIVATE_KEY --from-file <file>` — PEM can start with "-" and breaks argv).
JWT_PRIVATE_KEY=
JWKS=

# Google OAuth (Google Cloud Console → APIs & Services → Credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth (GitHub → Settings → Developer settings → OAuth Apps)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Meta / Facebook OAuth (Meta for Developers → App → Settings)
AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=

# Optional: comma-separated emails → "admin" membership on first sign-up
ADMIN_EMAILS=
