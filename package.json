{
  "name": "cemvp",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "pnpm --filter ./apps/forum dev",
    "build": "pnpm --filter ./apps/forum build",
    "start": "pnpm --filter ./apps/forum start",
    "lint": "pnpm --filter ./apps/forum lint",
    "typecheck": "pnpm --filter ./apps/forum typecheck",
    "dev:seller": "pnpm --filter @cemvp/seller dev",
    "dev:admin": "pnpm --filter @cemvp/admin dev",
    "dev:marketplace": "pnpm --filter @cemvp/marketplace dev",
    "build:seller": "pnpm --filter @cemvp/seller build",
    "build:admin": "pnpm --filter @cemvp/admin build",
    "build:marketplace": "pnpm --filter @cemvp/marketplace build",
    "lint:seller": "pnpm --filter @cemvp/seller lint",
    "lint:admin": "pnpm --filter @cemvp/admin lint",
    "lint:marketplace": "pnpm --filter @cemvp/marketplace lint",
    "typecheck:seller": "pnpm --filter @cemvp/seller typecheck",
    "typecheck:admin": "pnpm --filter @cemvp/admin typecheck",
    "typecheck:marketplace": "pnpm --filter @cemvp/marketplace typecheck",
    "convex:dev": "convex dev",
    "convex:codegen": "convex codegen",
    "convex:deploy:prod": "convex deploy",
    "convex:gen-jwt": "node scripts/generate-convex-auth-jwt.mjs"
  },
  "devDependencies": {
    "convex": "^1.34.1",
    "jose": "^6.2.2"
  },
  "dependencies": {
    "@auth/core": "0.37.0",
    "@convex-dev/auth": "^0.0.91"
  }
}
